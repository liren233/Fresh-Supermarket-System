<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<!--
      mapper为映射的根节点，用来管理DAO接口
      namespace指定DAO接口的完整类名，表示mapper配置文件管理哪个DAO接口(包.接口名)
      mybatis会依据这个接口动态创建一个实现类去实现这个接口，而这个实现类是一个Mapper对象
   -->
<!-- 修正1：namespace适配新DAO包路径（注意接口名是FOderDetailDao，保持和原接口一致） -->
<mapper namespace="com.xhm.main.dao.FOderDetailDao">
    <!-- 修正2：type指向新的Model包路径 + 修复javaType/jdbcType混用错误 -->
    <resultMap id="BaseResultMap" type="com.xhm.main.model.FOrderDetail" >
        <id column="id" property="id" jdbcType="INTEGER" />
        <result column="good_name" property="good_name" jdbcType="VARCHAR" />
        <result column="img_url" property="img_url" jdbcType="VARCHAR" />
        <result column="num" property="num" jdbcType="INTEGER" />
        <result column="intro" property="intro" jdbcType="VARCHAR" />
        <result column="price" property="price" jdbcType="DECIMAL"/>
        <result column="total_price" property="total_price" jdbcType="DECIMAL"/>
        <!-- 补充：新增order_id字段映射（原ResultMap缺失，适配插入/查询逻辑） -->
        <result column="order_id" property="order_id" jdbcType="INTEGER"/>
    </resultMap>

    <!-- 修正3：补充order_id字段到查询列，匹配实体类 -->
    <sql id="Base_Column_List">
        id,good_name,img_url,num,price,total_price,order_id
    </sql>

    <!--    分页查询订单详情（修正4：parameterType适配新Model包路径）-->
    <select id="list" resultMap="BaseResultMap" parameterType="com.xhm.main.model.Page">
        select <include refid="Base_Column_List"/>
        from f_orderdetail
        <if test="search != null and search!=''">
            where good_name like concat('%',#{search},'%')
        </if>
        <if test="start != null and start >=0 and count !=null">
            limit #{start},#{count}
        </if>
    </select>

    <!-- 分页总数查询（修正5：parameterType适配新Model包路径） -->
    <select id="total" parameterType="com.xhm.main.model.Page" resultType="java.lang.Integer">
        select count(1) from f_orderdetail
        <if test="search != null and search!=''">
            where good_name like concat('%',#{search},'%')
        </if>
    </select>

    <!-- 根据订单ID查询详情（补充jdbcType，规范语法） -->
    <select id="getByOrderId" resultMap="BaseResultMap" parameterType="java.lang.Integer" >
        select
        <include refid="Base_Column_List" />
        from f_orderdetail
        where order_id = #{id,jdbcType=INTEGER}
    </select>

    <!-- 根据ID查询订单详情（补充jdbcType，规范语法） -->
    <select id="getById" resultMap="BaseResultMap" parameterType="java.lang.Integer" >
        select
        <include refid="Base_Column_List" />
        from f_orderdetail
        where id = #{id,jdbcType=INTEGER}
    </select>

    <!--    添加订单详情（修复6：parameterType错误 BGood → FOrderDetail + 适配新包路径）-->
    <insert id="insert" keyProperty="id" keyColumn="id" parameterType="com.xhm.main.model.FOrderDetail" useGeneratedKeys="true">
        insert into f_orderdetail (good_name, price,num,img_url,total_price,order_id)
        values (#{good_name},#{price},#{num},#{img_url},#{total_price},#{order_id})
    </insert>

    <!--    删除订单详情-->
    <delete id="delete" parameterType="java.lang.Integer">
        delete from f_orderdetail
        where id = #{id,jdbcType=INTEGER}
    </delete>

    <!--    根据订单ID删除订单详情-->
    <delete id="deleteByOrderId" parameterType="java.lang.Integer">
        delete from f_orderdetail
        where order_id = #{order_id,jdbcType=INTEGER}
    </delete>
</mapper>