<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.xhm.main.dao.UserDao">
    <resultMap id="BaseResultMap" type="com.xhm.main.model.FUser" >
        <id column="id" property="id" jdbcType="INTEGER" />
        <result column="user_name" property="userName" jdbcType="VARCHAR" />
        <result column="pwd" property="pwd" jdbcType="VARCHAR" />
        <result column="status" property="status" jdbcType="INTEGER" />
        <result column="phone" property="phone" jdbcType="VARCHAR" />
    </resultMap>

    <sql id="Base_Column_List" >
        id, user_name, pwd,status,phone
    </sql>

    <!-- ========== 新增：根据用户名查询用户（核心修改） ========== -->
    <select id="findUserByUserName" resultMap="BaseResultMap" parameterType="java.lang.String">
        select
        <include refid="Base_Column_List" />
        from f_user
        where user_name = #{userName,jdbcType=VARCHAR}
    </select>

    <!-- 根据ID查询用户（原有代码保留） -->
    <select id="getUserById" resultMap="BaseResultMap" parameterType="java.lang.Integer" >
        select
        <include refid="Base_Column_List" />
        from f_user
        where id = #{id,jdbcType=INTEGER}
    </select>

    <!-- 用户登录（原有代码保留） -->
    <select id="userLogin"  resultMap="BaseResultMap" parameterType="com.xhm.main.model.FUser">
        select
        <include refid="Base_Column_List" />
        from f_user
        where user_name=#{userName} and pwd=#{pwd}
    </select>

    <!-- 添加用户信息（原有代码保留） -->
    <insert id="insertUser" keyColumn="id" keyProperty="id" parameterType="com.xhm.main.model.FUser" useGeneratedKeys="true">
        insert into f_user(user_name, pwd,status,phone) values (#{userName},#{pwd},#{status},#{phone})
    </insert>

    <!-- 用户列表基础查询（原有代码保留） -->
    <select id="userList" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"></include>
        from f_user
    </select>

    <!-- 分页查询用户（原有代码保留） -->
    <select id="list" resultMap="BaseResultMap" parameterType="com.xhm.main.model.Page">
        select
        <include refid="Base_Column_List"/>
        from f_user
        <if test="search != null and search!=''">
            where user_name like concat('%',#{search},'%') or phone like concat('%',#{search},'%')
        </if>
        <if test="start != null and start >=0 and count !=null">
            limit #{start},#{count}
        </if>
    </select>

    <!-- 分页总数查询（原有代码保留） -->
    <select id="total" parameterType="com.xhm.main.model.Page" resultType="java.lang.Integer">
        select count(1) from f_user
        <if test="search != null and search!=''">
            where user_name like concat('%',#{search},'%') or phone like concat('%',#{search},'%')
        </if>
    </select>

    <!-- 删除用户信息（原有代码保留） -->
    <delete id="deleteUser" parameterType="java.lang.Integer">
        delete from f_user
        where id = #{id,jdbcType=INTEGER}
    </delete>

    <!-- 修改用户信息（原有代码保留） -->
    <update id="updateUser" keyColumn="id" keyProperty="id" parameterType="com.xhm.main.model.FUser" useGeneratedKeys="true">
        update  f_user
        <set>
            <if test="userName != null">
                user_name = #{userName,jdbcType=VARCHAR},
            </if>
            <if test="pwd !=null">
                pwd = #{pwd,jdbcType=VARCHAR},
            </if>
            <if test="status !=null">
                `status` = #{status,jdbcType=INTEGER},
            </if>
            <if test="phone !=null">
                phone = #{phone,jdbcType=VARCHAR}
            </if>
        </set>
        where id = #{id,jdbcType=INTEGER}
    </update>

    <!-- 启用/禁用用户（原有代码保留） -->
    <update id="updateUserStatus" keyColumn="id" keyProperty="id" parameterType="com.xhm.main.model.FUser" useGeneratedKeys="true">
        update f_user set status = #{status,jdbcType=INTEGER} where id=#{id,jdbcType=INTEGER}
    </update>

</mapper>