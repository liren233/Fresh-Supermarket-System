<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<!--
      mapper为映射的根节点，用来管理DAO接口
      namespace指定DAO接口的完整类名，表示mapper配置文件管理哪个DAO接口(包.接口名)
      mybatis会依据这个接口动态创建一个实现类去实现这个接口，而这个实现类是一个Mapper对象
   -->
<!-- 修正1：namespace适配新DAO包路径（注意接口名大小写规范：AdminDao） -->
<mapper namespace="com.xhm.main.dao.adminDao">
    <!-- 修正2：type指向新的Model包路径 -->
    <resultMap id="BaseResultMap" type="com.xhm.main.model.BUser" >
        <id column="id" property="id" jdbcType="INTEGER" />
        <result column="user_name" property="userName" jdbcType="VARCHAR" />
        <result column="pwd" property="pwd" jdbcType="VARCHAR" />
        <result column="is_superuser" property="superuser" jdbcType="INTEGER" />
        <result column="phone" property="phone" jdbcType="VARCHAR" />
        <result column="status" property="status" jdbcType="INTEGER" />
    </resultMap>

    <!--    查询字段集合-->
    <sql id="Base_Column_List" >
        id, user_name, pwd,is_superuser,phone,status
    </sql>

    <!-- 根据ID查询管理员 -->
    <select id="getUserById" resultMap="BaseResultMap" parameterType="java.lang.Integer" >
        select
        <include refid="Base_Column_List" />
        from b_user
        where id = #{id,jdbcType=INTEGER}
    </select>

    <!-- 管理员登录 -->
    <select id="adminLogin"  resultMap="BaseResultMap" parameterType="com.xhm.main.model.BUser">
        select
        <include refid="Base_Column_List" />
        from b_user
        where user_name=#{userName} and pwd=#{pwd}
    </select>

    <!-- 管理员列表（基础查询） -->
    <select id="userList" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"></include>
        from b_user
    </select>

    <!--    添加管理员信息（修正3：parameterType适配新Model包路径）-->
    <insert id="insertUser" keyProperty="id" keyColumn="id" parameterType="com.xhm.main.model.BUser" useGeneratedKeys="true">
        insert into b_user (user_name, pwd,phone) values (#{userName},#{pwd},#{phone})
    </insert>

    <!--    修改管理员信息（修正4：parameterType适配新Model包路径 + 规范语法）-->
    <update id="updateUser" keyColumn="id" keyProperty="id" parameterType="com.xhm.main.model.BUser" useGeneratedKeys="true">
        update  b_user
        <set>
            <if test="userName != null">
                user_name = #{userName,jdbcType=VARCHAR},
            </if>
            <if test="pwd !=null">
                pwd = #{pwd,jdbcType=VARCHAR},
            </if>
            <if test="status !=null">
                `status` = #{status,jdbcType=INTEGER},
            </if>
            <if test="phone !=null">
                phone = #{phone,jdbcType=VARCHAR}
            </if>
        </set>
        where id = #{id,jdbcType=INTEGER}
    </update>

    <!--    删除管理员信息-->
    <delete id="deleteUser" parameterType="java.lang.Integer">
        delete from b_user
        where id = #{id,jdbcType=INTEGER}
    </delete>

    <!--    分页查询管理员（修正5：parameterType适配新Model包路径）-->
    <select id="list" resultMap="BaseResultMap" parameterType="com.xhm.main.model.Page">
        select
        <include refid="Base_Column_List"/>
        from b_user
        <if test="search != null and search!=''">
            where user_name like concat('%',#{search},'%') or phone like concat('%',#{search},'%')
        </if>
        <if test="start != null and start >=0 and count !=null">
            limit #{start},#{count}
        </if>
    </select>

    <!-- 分页总数查询（修正6：parameterType适配新Model包路径） -->
    <select id="total" parameterType="com.xhm.main.model.Page" resultType="java.lang.Integer">
        select count(1) from b_user
        <if test="search != null and search!=''">
            where user_name like concat('%',#{search},'%') or phone like concat('%',#{search},'%')
        </if>
    </select>

    <!-- 启用/禁用管理员（修正7：parameterType适配新Model包路径） -->
    <update id="updateStatus" keyColumn="id" keyProperty="id" parameterType="com.xhm.main.model.BUser" useGeneratedKeys="true">
        update b_user set status = #{status,jdbcType=INTEGER} where id=#{id,jdbcType=INTEGER}
    </update>

</mapper>